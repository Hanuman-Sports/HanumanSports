# ============================================
# Hanuman Sports - Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# JWT Configuration (required — use a random string)
JWT_SECRET=your_random_secret_here

# Server Configuration
PORT=3000

# Razorpay Configuration (optional — leave blank to disable payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
